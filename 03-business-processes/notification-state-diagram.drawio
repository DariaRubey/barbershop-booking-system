      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="goal" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#888888;fontSize=13;" value="&lt;b&gt;Цель(назначение):&lt;/b&gt; показать жизненный цикл уведомления клиенту: от создания после записи до доставки, ошибки или отмены" vertex="1">
